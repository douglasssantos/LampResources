# ─── Helpers visuais ──────────────────────────────────────────────────────────
sep()    { echo "  ${CINZA}────────────────────────────────────────────────${RESET}"; }
linha()  { echo "  ${CINZA}════════════════════════════════════════════════${RESET}"; }

titulo() { echo; echo "  ${NEGRITO}${CIANO_CLARO}$1${RESET}"; sep; }

