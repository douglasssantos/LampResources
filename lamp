BackupBancoPostgres(){
  echo
  echo -n " >>> Digite o nome do banco de dados: "
  read pgdb
  echo "============================"
  timestamp=$(date +"%Y%m%d_%H%M%S")
  backupfile="/var/backups/pg_${pgdb}_${timestamp}.sql"
  sudo mkdir -p /var/backups
  echo "Criando backup do banco $pgdb!..."
  sudo -u postgres pg_dump $pgdb > $backupfile
  echo "============================"
  echo
  if [ -f "$backupfile" ]; then
    tamanho=$(du -sh $backupfile | awk '{print $1}')
    echo " Backup criado com sucesso!"
    echo " Arquivo: $backupfile"
    echo " Tamanho: $tamanho"
  else
    echo " Falha ao criar o backup!"
  fi
  echo "============================"
  echo
  echo "Digite enter para voltar ao Menu"
  read
  MenuPostgres
}
RestaurarBancoPostgres(){
  echo
  echo "============================"
  echo "  Backups disponíveis em /var/backups  "
  echo "============================"
  ls /var/backups/pg_*.sql 2>/dev/null || echo "Nenhum backup de banco encontrado."
  echo "============================"
  echo
  echo -n " >>> Digite o caminho completo do arquivo .sql: "
  read backupfile
  echo "============================"
  echo -n " >>> Digite o nome do banco de destino: "
  read pgdb
  echo "============================"
  echo "Restaurando banco $pgdb!..."
  sudo -u postgres psql -c "CREATE DATABASE $pgdb;" 2>/dev/null || true
  sudo -u postgres psql $pgdb < $backupfile
  echo "============================"
  echo " Banco $pgdb restaurado com sucesso!"
  echo "============================"
  echo
  echo "Digite enter para voltar ao Menu"
  read
  MenuPostgres
}
