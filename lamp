BackupBancoPostgres(){
  titulo "Backup de Banco PostgreSQL"
  entrada "Nome do banco de dados:"
  read pgdb
  sep
  timestamp=$(date +"%Y%m%d_%H%M%S")
  backupfile="/var/backups/pg_${pgdb}_${timestamp}.sql"
  sudo mkdir -p /var/backups
  info "Criando backup do banco $pgdb..."
  sudo -u postgres pg_dump $pgdb > $backupfile
  sep
  if [ -f "$backupfile" ]; then
    tamanho=$(du -sh $backupfile | awk '{print $1}')
    ok "Backup criado com sucesso!"
    item "Arquivo: $backupfile"
    item "Tamanho: $tamanho"
  else
    erro "Falha ao criar o backup!"
  fi
  linha
  pausar
  MenuPostgres
}
RestaurarBancoPostgres(){
  titulo "Restaurar Banco PostgreSQL"
  info "Backups disponíveis em /var/backups:"
  sep
  ls /var/backups/pg_*.sql 2>/dev/null || aviso "Nenhum backup de banco encontrado."
  sep
  entrada "Caminho completo do arquivo .sql:"
  read backupfile
  sep
  entrada "Nome do banco de destino:"
  read pgdb
  sep
  info "Restaurando banco $pgdb..."
  sudo -u postgres psql -c "CREATE DATABASE $pgdb;" 2>/dev/null || true
  sudo -u postgres psql $pgdb < $backupfile
  ok "Banco $pgdb restaurado com sucesso!"
  linha
  pausar
  MenuPostgres
}
