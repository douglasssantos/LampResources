# ─── Helpers visuais ──────────────────────────────────────────────────────────
sep()    { echo -e "${CINZA}  ────────────────────────────────────────────────${RESET}"; }
linha()  { echo -e "${CINZA}  ════════════════════════════════════════════════${RESET}"; }

titulo() { echo; echo -e "  ${NEGRITO}${CIANO_CLARO}$1${RESET}"; sep; }

ok()     { echo -e "  ${VERDE_CLARO}✔  ${BRANCO}$1${RESET}"; }
erro()   { echo -e "  ${VERMELHO}✖  ${BRANCO}$1${RESET}"; }
info()   { echo -e "  ${AMARELO_CLARO}➜  ${BRANCO}$1${RESET}"; }
aviso()  { echo -e "  ${AMARELO}⚠   ${BRANCO}$1${RESET}"; }
item()   { echo -e "  ${CIANO}•  ${BRANCO}$1${RESET}"; }

entrada(){
  echo -en "  ${CIANO}▶  ${AMARELO_CLARO}$1${RESET} "
}

pausar() {
  echo
  echo -en "  ${CINZA}Pressione ENTER para voltar...${RESET}"
  read
}

cabecalho(){
  local titulo="$1"
  local subtitulo="$2"
  clear
  echo
  echo -e "  ${NEGRITO}${BG_PRETO}${CIANO_CLARO}                                                    ${RESET}"
  echo -e "  ${NEGRITO}${BG_PRETO}${CIANO_CLARO}   $titulo${RESET}"
  if [[ -n "$subtitulo" ]]; then
    echo -e "  ${NEGRITO}${BG_PRETO}${CINZA}   $subtitulo${RESET}"
  fi
  echo -e "  ${NEGRITO}${BG_PRETO}${CIANO_CLARO}                                                    ${RESET}"
  echo
}

opcao_menu(){
  local num="$1"
  local desc="$2"
  printf "  ${CIANO}[${AMARELO_CLARO}%2s${CIANO}]${RESET}  %s\n" "$num" "$desc"
}

clear

