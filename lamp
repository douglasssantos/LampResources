# ─── Diretório dos módulos ────────────────────────────────────────────────────
LAMP_MODULES_DIR="/usr/local/lib/lamp/modules"

# Fallback para desenvolvimento local (execução direta do repositório)
if [[ ! -d "$LAMP_MODULES_DIR" ]]; then
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  LAMP_MODULES_DIR="$SCRIPT_DIR/modules"
fi

# ─── Verificar módulos ────────────────────────────────────────────────────────
if [[ ! -d "$LAMP_MODULES_DIR" ]]; then
  echo "Erro: diretório de módulos não encontrado em $LAMP_MODULES_DIR"
  echo "Execute: sudo ./install"
  exit 1
fi

# ─── Carregar módulos na ordem correta ────────────────────────────────────────
_lamp_modules=(
  _helpers
  php
  redis
  postgres
  mysql
  mongodb
  sistema
  apache
  node
)

for _mod in "${_lamp_modules[@]}"; do
  _mod_file="$LAMP_MODULES_DIR/${_mod}.sh"
  if [[ -f "$_mod_file" ]]; then
    # shellcheck source=/dev/null
    source "$_mod_file"
  else
    echo "Aviso: módulo '${_mod}.sh' não encontrado em $LAMP_MODULES_DIR"
  fi
done
unset _mod _mod_file _lamp_modules

# ─── Variável global ──────────────────────────────────────────────────────────
