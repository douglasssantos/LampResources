ConfigurarPhpIni(){
  echo
  vphp=$(php -v 2>/dev/null | head -1 | grep -oP '\d+\.\d+' | head -1)
  phpini="/etc/php/$vphp/apache2/php.ini"
  echo "============================"
  echo "  Configurar php.ini — PHP $vphp  "
  echo "  Arquivo: $phpini"
  echo "============================"
  echo
  echo " Valores atuais:"
  echo -n "  memory_limit:         "; grep "^memory_limit" $phpini 2>/dev/null | awk '{print $3}'
  echo -n "  upload_max_filesize:  "; grep "^upload_max_filesize" $phpini 2>/dev/null | awk '{print $3}'
  echo -n "  post_max_size:        "; grep "^post_max_size" $phpini 2>/dev/null | awk '{print $3}'
  echo -n "  max_execution_time:   "; grep "^max_execution_time" $phpini 2>/dev/null | awk '{print $3}'
  echo
  echo "============================"
  echo -n " >>> memory_limit (ex: 256M) [enter para manter]: "
  read val_memory
  echo -n " >>> upload_max_filesize (ex: 64M) [enter para manter]: "
  read val_upload
  echo -n " >>> post_max_size (ex: 64M) [enter para manter]: "
  read val_post
  echo -n " >>> max_execution_time (ex: 300) [enter para manter]: "
  read val_exec
  echo "============================"
  echo
  if [[ -n "$val_memory" ]]; then
    sudo sed -i "s/^memory_limit.*/memory_limit = $val_memory/" $phpini
    echo " memory_limit definido para $val_memory"
  fi
  if [[ -n "$val_upload" ]]; then
    sudo sed -i "s/^upload_max_filesize.*/upload_max_filesize = $val_upload/" $phpini
    echo " upload_max_filesize definido para $val_upload"
  fi
  if [[ -n "$val_post" ]]; then
    sudo sed -i "s/^post_max_size.*/post_max_size = $val_post/" $phpini
    echo " post_max_size definido para $val_post"
  fi
  if [[ -n "$val_exec" ]]; then
    sudo sed -i "s/^max_execution_time.*/max_execution_time = $val_exec/" $phpini
    echo " max_execution_time definido para $val_exec"
  fi
  echo
  echo "Reiniciando Apache para aplicar as alterações!..."
  sudo systemctl restart apache2
  echo "Apache reiniciado com sucesso!"
  echo "============================"
  echo
  echo "Digite enter para voltar ao Menu"
  read
  MenuPHP
}

