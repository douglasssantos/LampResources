#!/bin/bash

# Created by: Douglas S. Santos
# E-mail: douglassantos2127@gmail.com
# whatsapp: +55 21 97553-3534

INSTALL_VERSION="2.0"
INSTALL_SRC="./lamp"
INSTALL_DST="/usr/local/bin/lamp"
MODULES_SRC="./modules"
MODULES_DST="/usr/local/lib/lamp/modules"

MODULES_LIST=(
  _helpers
  php
  redis
  postgres
  mysql
  sistema
  apache
  node
)

# ─── Cores (inline — independente do lamp) ───────────────────────────────────
RESET=$'\e[0m'
NEGRITO=$'\e[1m'
VERMELHO=$'\e[31m'
VERDE_CLARO=$'\e[92m'
AMARELO=$'\e[33m'
AMARELO_CLARO=$'\e[93m'
CIANO=$'\e[36m'
CIANO_CLARO=$'\e[96m'
BRANCO=$'\e[37m'
CINZA=$'\e[90m'
BG_PRETO=$'\e[40m'

# ─── Helpers ──────────────────────────────────────────────────────────────────
sep()   { echo "  ${CINZA}────────────────────────────────────────────────${RESET}"; }
linha() { echo "  ${CINZA}════════════════════════════════════════════════${RESET}"; }
ok()    { echo "  ${VERDE_CLARO}✔  ${BRANCO}$1${RESET}"; }
erro()  { echo "  ${VERMELHO}✖  ${BRANCO}$1${RESET}"; echo; exit 1; }
info()  { echo "  ${AMARELO_CLARO}➜  ${BRANCO}$1${RESET}"; }
aviso() { echo "  ${AMARELO}⚠   ${BRANCO}$1${RESET}"; }
item()  { echo "  ${CIANO}•  ${BRANCO}$1${RESET}"; }
entrada(){ printf "  ${CIANO}▶  ${AMARELO_CLARO}%s${RESET} " "$1"; }

cabecalho(){
  clear
  echo
  echo "  ${NEGRITO}${BG_PRETO}${CIANO_CLARO}                                                    ${RESET}"
  echo "  ${NEGRITO}${BG_PRETO}${CIANO_CLARO}   LAMP RESOURCES — Instalador v${INSTALL_VERSION}${RESET}"
  echo "  ${NEGRITO}${BG_PRETO}${CINZA}   Douglas S. Santos  •  douglassantos2127@gmail.com${RESET}"
  echo "  ${NEGRITO}${BG_PRETO}${CIANO_CLARO}                                                    ${RESET}"
  echo
}

opcao_menu(){ printf "  ${CIANO}[${AMARELO_CLARO}%s${CIANO}]${RESET}  %s\n" "$1" "$2"; }

# ─── Cabeçalho ────────────────────────────────────────────────────────────────
cabecalho

# ─── Verificar permissão sudo ─────────────────────────────────────────────────
if [[ $EUID -ne 0 ]] && ! sudo -n true 2>/dev/null; then
  erro "Execute com sudo: sudo ./install"
fi

# ─── Verificar arquivo principal ──────────────────────────────────────────────
if [[ ! -f "$INSTALL_SRC" ]]; then
  erro "Arquivo '$INSTALL_SRC' não encontrado. Execute o instalador na pasta do repositório."
fi

# ─── Verificar módulos ────────────────────────────────────────────────────────
info "Verificando módulos..."
modulos_ok=true
for mod in "${MODULES_LIST[@]}"; do
  if [[ -f "$MODULES_SRC/${mod}.sh" ]]; then
    ok "  modules/${mod}.sh"
  else
    aviso "  AUSENTE: modules/${mod}.sh"
    modulos_ok=false
  fi
done

if ! $modulos_ok; then
  echo
  aviso "Um ou mais módulos estão ausentes. A instalação pode ser incompleta."
  entrada "Continuar mesmo assim? (y/n):"
  read continuar
  [[ "$continuar" != "y" && "$continuar" != "Y" ]] && echo && exit 0
fi

# ─── Detectar instalação existente ───────────────────────────────────────────
sep
MODO="instalar"
if [[ -f "$INSTALL_DST" ]]; then
  aviso "Lamp já está instalado em $INSTALL_DST"
  echo
  opcao_menu 1 "Atualizar"
  opcao_menu 2 "Desinstalar"
  opcao_menu 3 "Cancelar"
  echo
  entrada "Escolha uma opção:"
  read opcao
  echo
  sep
  case "$opcao" in
    1) MODO="atualizar" ;;
    2) MODO="desinstalar" ;;
    *) aviso "Operação cancelada."; echo; exit 0 ;;
  esac
fi

# ─── Desinstalar ──────────────────────────────────────────────────────────────
if [[ "$MODO" == "desinstalar" ]]; then
  info "Removendo $INSTALL_DST..."
  sudo rm -f "$INSTALL_DST"
  info "Removendo módulos em $MODULES_DST..."
  sudo rm -rf "$MODULES_DST"
  sudo rmdir /usr/local/lib/lamp 2>/dev/null || true
  if [[ ! -f "$INSTALL_DST" ]]; then
    ok "Lamp desinstalado com sucesso!"
  else
    erro "Falha ao remover $INSTALL_DST"
  fi
  linha
  echo
  exit 0
fi

# ─── Resumo ───────────────────────────────────────────────────────────────────
echo "  ${NEGRITO}${BRANCO}O seguinte será instalado:${RESET}"
echo
item "Script principal  →  $INSTALL_DST"
item "Módulos (${#MODULES_LIST[@]} arquivos)  →  $MODULES_DST/"
echo
if [[ "$MODO" == "atualizar" ]]; then
  entrada "Confirmar atualização? (y/n):"
else
  entrada "Confirmar instalação? (y/n):"
fi
read confirmar
echo
[[ "$confirmar" != "y" && "$confirmar" != "Y" ]] && aviso "Operação cancelada." && echo && exit 0

sep

TOTAL=4
erros=0

# ── Passo 1 — Criar diretórios ────────────────────────────────────────────────
echo
echo "  ${CINZA}[${AMARELO_CLARO}1${CINZA}/${AMARELO_CLARO}${TOTAL}${CINZA}]${RESET}  ${NEGRITO}${BRANCO}Criar diretórios${RESET}"
sep
if sudo mkdir -p "$MODULES_DST"; then
  ok "Diretório criado: $MODULES_DST"
else
  aviso "Não foi possível criar $MODULES_DST"
  erros=$((erros+1))
fi

# ── Passo 2 — Instalar módulos ────────────────────────────────────────────────
echo
echo "  ${CINZA}[${AMARELO_CLARO}2${CINZA}/${AMARELO_CLARO}${TOTAL}${CINZA}]${RESET}  ${NEGRITO}${BRANCO}Instalar módulos${RESET}"
sep
for mod in "${MODULES_LIST[@]}"; do
  src="$MODULES_SRC/${mod}.sh"
  dst="$MODULES_DST/${mod}.sh"
  if [[ -f "$src" ]]; then
    if sudo cp -f "$src" "$dst" && sudo chmod 644 "$dst"; then
      ok "  ${mod}.sh"
    else
      aviso "  Falha ao copiar ${mod}.sh"
      erros=$((erros+1))
    fi
  else
    aviso "  Ignorado (ausente): ${mod}.sh"
  fi
done

# ── Passo 3 — Instalar script principal ───────────────────────────────────────
echo
echo "  ${CINZA}[${AMARELO_CLARO}3${CINZA}/${AMARELO_CLARO}${TOTAL}${CINZA}]${RESET}  ${NEGRITO}${BRANCO}Instalar script principal${RESET}"
sep
if sudo cp -f "$INSTALL_SRC" "$INSTALL_DST" && sudo chmod +x "$INSTALL_DST"; then
  ok "lamp instalado em $INSTALL_DST"
else
  erro "Falha ao copiar lamp para $INSTALL_DST"
fi

# ── Passo 4 — Verificação final ────────────────────────────────────────────────
echo
echo "  ${CINZA}[${AMARELO_CLARO}4${CINZA}/${AMARELO_CLARO}${TOTAL}${CINZA}]${RESET}  ${NEGRITO}${BRANCO}Verificação final${RESET}"
sep

total_mods=0
for mod in "${MODULES_LIST[@]}"; do
  if [[ -f "$MODULES_DST/${mod}.sh" ]]; then
    total_mods=$((total_mods+1))
  fi
done

if [[ -x "$INSTALL_DST" ]]; then
  ok "Script principal: $INSTALL_DST  ✔"
fi
ok "Módulos instalados: $total_mods / ${#MODULES_LIST[@]}"

# ─── Sumário ──────────────────────────────────────────────────────────────────
linha
echo
if [[ $erros -eq 0 ]]; then
  if [[ "$MODO" == "atualizar" ]]; then
    echo "  ${NEGRITO}${VERDE_CLARO}✔  Lamp atualizado com sucesso!${RESET}"
  else
    echo "  ${NEGRITO}${VERDE_CLARO}✔  Lamp instalado com sucesso!${RESET}"
  fi
else
  aviso "Instalação concluída com $erros erro(s)."
fi
echo
item "Binário:   $INSTALL_DST"
item "Módulos:   $MODULES_DST/"
item "Versão:    $INSTALL_VERSION"
echo
echo "  ${CINZA}Para usar:${RESET}  ${NEGRITO}${CIANO_CLARO}sudo lamp${RESET}"
echo
linha
echo
entrada "Deseja executar o Lamp agora? (y/n):"
read executar
echo
if [[ "$executar" == "y" || "$executar" == "Y" ]]; then
  echo
  sudo lamp
fi
